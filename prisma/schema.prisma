// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// MULTI-TENANCY & AUTHENTICATION
// ============================================================================

model Tenant {
  id                String     @id @default(cuid())
  name              String     @unique
  code              String     @unique
  country           String     @default("Nigeria")
  email             String     @unique
  phone             String?
  status            String     @default("active") // active, suspended, inactive
  logo              String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  users             User[]
  settings          TenantSettings?
  students          Student[]
  staff             Staff[]
  classes           Class[]
  subjects          Subject[]
  classSubjects     ClassSubject[]
  timetables        Timetable[]
  assignments       Assignment[]
  exams             Exam[]
  examSchedules     ExamSchedule[]
  examResults       ExamResult[]
  studentTranscripts StudentTranscript[]
  schoolFees        SchoolFee[]
  feePayments       FeePayment[]
  schoolExpenses    SchoolExpense[]
  financialReports  FinancialReport[]
  
  crops             Crop[]
  farmPlots         FarmPlot[]
  cropActivities    CropActivity[]
  livestock        Livestock[]
  livestockRecords  LivestockRecord[]
  livestockExpenses LivestockExpense[]
  inventoryItems    InventoryItem[]
  inventoryTransactions InventoryTransaction[]
  fertilizers       Fertilizer[]
  seeds             Seed[]
  farmWorkers       FarmWorker[]
  workerAssignments WorkerAssignment[]
  farmTasks         FarmTask[]
  workerPayroll     WorkerPayroll[]
  produce           Produce[]
  sales             Sale[]
  farmExpenses      FarmExpense[]
  farmRevenue       FarmRevenue[]
  farmMetrics       FarmMetrics[]
  
  notifications     Notification[]
  auditLogs         AuditLog[]
  systemLogs        SystemLog[]

  @@map("tenants")
}

model TenantSettings {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Feature flags
  academicEnabled   Boolean  @default(true)
  farmEnabled       Boolean  @default(true)
  financeEnabled    Boolean  @default(true)
  
  // SMS Configuration
  smsProvider       String?  // twilio, termii, flutterwave
  smsApiKey         String?
  smsApiSecret      String?
  
  // Notifications
  emailNotifications    Boolean @default(true)
  smsNotifications      Boolean @default(false)
  pushNotifications     Boolean @default(true)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("tenant_settings")
}

model User {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  email             String
  phone             String?
  passwordHash      String
  firstName         String
  lastName          String
  role              String   // admin, teacher, farm_manager, student, parent, farm_worker
  status            String   @default("active") // active, inactive, suspended
  
  // Profile info
  avatar            String?
  bio               String?
  department        String?  // for teachers
  
  // Timestamps
  lastLogin         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  studentProfile    Student?
  staffProfile      Staff?
  parentChildren    StudentParent[] @relation("parent")
  
  auditLogs         AuditLog[] @relation("user_actions")
  notifications     Notification[]
  refreshTokens     RefreshToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token             String   @unique
  expiresAt         DateTime
  createdAt         DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================================================
// SCHOOL MODULE - STUDENTS
// ============================================================================

model Student {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  regNumber          String   @unique
  dateOfBirth       DateTime
  gender            String   // male, female, other
  address           String?
  
  classId           String?
  class             Class?   @relation(fields: [classId], references: [id])
  
  status            String   @default("active") // active, graduated, transferred, suspended
  admissionDate     DateTime @default(now())
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  parents           StudentParent[]
  documents         StudentDocument[]
  assignmentSubmissions AssignmentSubmission[]
  examResults       ExamResult[]
  transcripts       StudentTranscript[]
  feePayments       FeePayment[]
  notifications     Notification[] @relation("student_notifications")

  @@unique([tenantId, regNumber])
  @@index([tenantId])
  @@index([classId])
  @@map("students")
}

model StudentParent {
  id                String   @id @default(cuid())
  tenantId          String
  
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  parentId          String
  parent            User     @relation("parent", fields: [parentId], references: [id], onDelete: Cascade)
  
  relationship      String   // mother, father, guardian, other
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([studentId, parentId])
  @@index([studentId])
  @@map("student_parents")
}

model StudentDocument {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  documentType      String   // birth_certificate, passport, vaccination, transcript
  fileUrl           String
  uploadedAt        DateTime @default(now())
  expiryDate        DateTime?

  @@index([studentId])
  @@map("student_documents")
}

// ============================================================================
// SCHOOL MODULE - STAFF & ATTENDANCE
// ============================================================================

model Staff {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  staffId           String   @unique
  department        String   // academics, administration, support
  position          String   // teacher, head_teacher, admin, etc
  
  qualifications    String?  // comma-separated
  employmentDate    DateTime @default(now())
  status            String   @default("active") // active, on_leave, retired
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  classSubjects     ClassSubject[] @relation("teacher")
  attendance        StaffAttendance[]
  payroll           StaffPayroll[]

  @@unique([tenantId, staffId])
  @@index([tenantId])
  @@map("staff")
}

model StaffAttendance {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  staffId           String
  staff             Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  
  date              DateTime
  status            String   // present, absent, late, excused
  checkIn           DateTime?
  checkOut          DateTime?
  notes             String?
  
  createdAt         DateTime @default(now())

  @@unique([staffId, date])
  @@index([staffId])
  @@index([date])
  @@map("staff_attendance")
}

model StaffPayroll {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  staffId           String
  staff             Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  
  period            String   // YYYY-MM
  baseSalary        Float
  allowances        Float    @default(0)
  deductions        Float    @default(0)
  netSalary         Float
  
  status            String   @default("pending") // pending, approved, paid
  paidDate          DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([staffId, period])
  @@index([staffId])
  @@map("staff_payroll")
}

// ============================================================================
// SCHOOL MODULE - ACADEMICS
// ============================================================================

model Class {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name              String   // JSS1, JSS2, SSS1, etc
  level             String   // junior, senior
  capacity          Int      @default(50)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  students          Student[]
  classSubjects     ClassSubject[]
  timetables        Timetable[]
  assignments       Assignment[] @relation("class_assignments")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("classes")
}

model Subject {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name              String   // Mathematics, English, etc
  code              String
  description       String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  classSubjects     ClassSubject[]
  timetables        Timetable[]
  assignments       Assignment[]
  examSchedules     ExamSchedule[]
  
  crops             Crop[] @relation("subject_crops")
  seeds             Seed[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("subjects")
}

model ClassSubject {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  classId           String
  class             Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  
  subjectId         String
  subject           Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  
  teacherId         String
  teacher           Staff    @relation("teacher", fields: [teacherId], references: [id], onDelete: SetNull)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([classId, subjectId])
  @@index([classId])
  @@index([subjectId])
  @@map("class_subjects")
}

model Timetable {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  classId           String
  class             Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  
  subjectId         String
  subject           Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  
  day               String   // Monday, Tuesday, etc
  startTime         String   // HH:MM
  endTime           String   // HH:MM
  room              String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([classId, day, startTime])
  @@index([classId])
  @@map("timetables")
}

model Assignment {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  classId           String?
  class             Class?   @relation("class_assignments", fields: [classId], references: [id])
  
  subjectId         String
  subject           Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  
  title             String
  description       String
  dueDate           DateTime
  maxScore          Float    @default(100)
  
  status            String   @default("draft") // draft, published, closed
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  submissions       AssignmentSubmission[]

  @@index([subjectId])
  @@index([classId])
  @@map("assignments")
}

model AssignmentSubmission {
  id                String   @id @default(cuid())
  tenantId          String
  
  assignmentId      String
  assignment        Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  fileUrl           String?
  submissionDate    DateTime @default(now())
  status            String   @default("submitted") // submitted, graded, late
  
  score             Float?
  feedback          String?
  gradedAt          DateTime?
  
  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
  @@map("assignment_submissions")
}

model Exam {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name              String   // Midterm, Final, etc
  startDate         DateTime
  endDate           DateTime
  status            String   @default("scheduled") // scheduled, in_progress, completed
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  schedules         ExamSchedule[]
  results           ExamResult[]

  @@index([tenantId])
  @@map("exams")
}

model ExamSchedule {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  examId            String
  exam              Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  subjectId         String
  subject           Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  
  date              DateTime
  startTime         String   // HH:MM
  duration          Int      // minutes
  maxScore          Float    @default(100)
  
  @@unique([examId, subjectId])
  @@index([examId])
  @@map("exam_schedules")
}

model ExamResult {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  examId            String
  exam              Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  subjectId         String
  subject           Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  
  score             Float
  totalScore        Float    @default(100)
  grade             String?  // A, B, C, D, F
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([examId, studentId, subjectId])
  @@index([examId])
  @@index([studentId])
  @@map("exam_results")
}

model StudentTranscript {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  term              String   // Term 1, Term 2, etc
  academicYear      String   // 2023/2024
  gpa               Float    @default(0)
  comments          String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([studentId, term, academicYear])
  @@index([studentId])
  @@map("student_transcripts")
}

// ============================================================================
// SCHOOL MODULE - FINANCE
// ============================================================================

model SchoolFee {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  amount            Float
  dueDate           DateTime
  academicYear      String   // 2023/2024
  term              String   // Term 1, Term 2, etc
  
  description       String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  payments          FeePayment[]

  @@index([tenantId])
  @@map("school_fees")
}

model FeePayment {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  feeId             String?
  fee               SchoolFee? @relation(fields: [feeId], references: [id])
  
  amount            Float
  paymentDate       DateTime @default(now())
  paymentMethod     String   // cash, bank_transfer, online
  reference         String?  // for bank/online payments
  status            String   @default("completed") // pending, completed, failed
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([studentId])
  @@index([feeId])
  @@map("fee_payments")
}

model SchoolExpense {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  category          String   // utilities, maintenance, supplies, etc
  description       String
  amount            Float
  date              DateTime @default(now())
  
  approvedBy        String?
  status            String   @default("pending") // pending, approved, rejected
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@index([date])
  @@map("school_expenses")
}

model FinancialReport {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  period            String   // YYYY-MM
  totalRevenue      Float    @default(0)
  totalExpenses     Float    @default(0)
  balance           Float    @default(0)
  
  reportData        String?  // JSON for detailed breakdown
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([tenantId, period])
  @@index([tenantId])
  @@map("financial_reports")
}

// ============================================================================
// FARM MODULE - CROPS & PLOTS
// ============================================================================

model Crop {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name              String   // Maize, Rice, Cassava, etc
  scientificName    String?
  season            String   // dry, rainy, both
  description       String?
  
  // Link to academic subject for experimental learning
  subjectId         String?
  subject           Subject? @relation("subject_crops", fields: [subjectId], references: [id])
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  plots             FarmPlot[]
  produce           Produce[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("crops")
}

model FarmPlot {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name              String
  sizeHectares      Float
  soilType          String?  // loam, clay, sandy, etc
  
  cropId            String?
  crop              Crop?    @relation(fields: [cropId], references: [id])
  
  plantingDate      DateTime?
  expectedHarvest   DateTime?
  status            String   @default("idle") // idle, planting, growing, ready_harvest, harvested
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  activities        CropActivity[]
  tasks             FarmTask[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([cropId])
  @@map("farm_plots")
}

model CropActivity {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  plotId            String
  plot              FarmPlot @relation(fields: [plotId], references: [id], onDelete: Cascade)
  
  activityType      String   // planting, watering, weeding, fertilizing, spraying, harvesting
  date              DateTime @default(now())
  description       String?
  cost              Float    @default(0)
  
  createdAt         DateTime @default(now())

  @@index([plotId])
  @@index([date])
  @@map("crop_activities")
}

// ============================================================================
// FARM MODULE - LIVESTOCK
// ============================================================================

model Livestock {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  type              String   // cattle, poultry, goat, sheep, pig, etc
  breed             String?
  count             Int      @default(1)
  
  purchaseDate      DateTime
  cost              Float    @default(0)
  
  status            String   @default("active") // active, sold, dead
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  records           LivestockRecord[]
  expenses          LivestockExpense[]

  @@index([tenantId])
  @@map("livestock")
}

model LivestockRecord {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  livestockId       String
  livestock         Livestock @relation(fields: [livestockId], references: [id], onDelete: Cascade)
  
  date              DateTime @default(now())
  healthStatus      String   // healthy, sick, vaccinated, etc
  weight            Float?
  notes             String?
  
  createdAt         DateTime @default(now())

  @@index([livestockId])
  @@index([date])
  @@map("livestock_records")
}

model LivestockExpense {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  livestockId       String
  livestock         Livestock @relation(fields: [livestockId], references: [id], onDelete: Cascade)
  
  expenseType       String   // feed, veterinary, vaccination, transport, etc
  amount            Float
  date              DateTime @default(now())
  description       String?
  
  createdAt         DateTime @default(now())

  @@index([livestockId])
  @@map("livestock_expenses")
}

// ============================================================================
// FARM MODULE - INVENTORY
// ============================================================================

model InventoryItem {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name              String
  category          String   // tools, equipment, supplies, etc
  quantity          Int      @default(0)
  unit              String   // pieces, kg, liters, etc
  minStock          Int      @default(0)
  costPerUnit       Float
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  transactions      InventoryTransaction[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("inventory_items")
}

model InventoryTransaction {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  itemId            String
  item              InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  transactionType   String   // in, out, adjustment
  quantity          Int
  date              DateTime @default(now())
  notes             String?
  
  createdAt         DateTime @default(now())

  @@index([itemId])
  @@index([date])
  @@map("inventory_transactions")
}

model Fertilizer {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name              String
  type              String   // organic, inorganic, mixed
  quantity          Int      // in bags/units
  costPerBag        Float
  dateAdded         DateTime @default(now())
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@map("fertilizers")
}

model Seed {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  cropId            String
  crop              Subject  @relation(fields: [cropId], references: [id], onDelete: Cascade)
  
  variety           String
  quantity          Int
  cost              Float
  expiryDate        DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([cropId, variety])
  @@index([tenantId])
  @@index([cropId])
  @@map("seeds")
}

// ============================================================================
// FARM MODULE - WORKERS & TASKS
// ============================================================================

model FarmWorker {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name              String
  role              String   // laborer, supervisor, specialist
  contact           String
  
  hireDate          DateTime @default(now())
  status            String   @default("active") // active, on_leave, terminated
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  assignments       WorkerAssignment[]
  payroll           WorkerPayroll[]

  @@index([tenantId])
  @@map("farm_workers")
}

model FarmTask {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  plotId            String?
  plot              FarmPlot? @relation(fields: [plotId], references: [id], onDelete: SetNull)
  
  taskType          String   // planting, weeding, watering, etc
  description       String
  dueDate           DateTime
  
  assignedTo        String?
  status            String   @default("pending") // pending, in_progress, completed
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  assignments       WorkerAssignment[]

  @@index([plotId])
  @@index([dueDate])
  @@map("farm_tasks")
}

model WorkerAssignment {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  workerId          String
  worker            FarmWorker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  
  taskId            String
  task              FarmTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  date              DateTime
  status            String   @default("assigned") // assigned, in_progress, completed
  notes             String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([workerId, taskId])
  @@index([workerId])
  @@index([taskId])
  @@map("worker_assignments")
}

model WorkerPayroll {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  workerId          String
  worker            FarmWorker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  
  period            String   // YYYY-MM
  daysWorked        Int
  dailyRate         Float
  totalEarned       Float
  
  status            String   @default("pending") // pending, approved, paid
  paidDate          DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([workerId, period])
  @@index([workerId])
  @@map("worker_payroll")
}

// ============================================================================
// FARM MODULE - PRODUCE & SALES
// ============================================================================

model Produce {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  cropId            String
  crop              Crop     @relation(fields: [cropId], references: [id], onDelete: Cascade)
  
  harvestDate       DateTime
  quantity          Int
  unit              String   // kg, bags, tons, etc
  qualityGrade      String?  // A, B, C, etc
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  sales             Sale[]

  @@index([cropId])
  @@index([harvestDate])
  @@map("produce")
}

model Sale {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  produceId         String
  produce           Produce  @relation(fields: [produceId], references: [id], onDelete: Cascade)
  
  buyerName         String
  quantity          Int
  unit              String
  unitPrice         Float
  totalAmount       Float
  saleDate          DateTime @default(now())
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([produceId])
  @@index([saleDate])
  @@map("sales")
}

model FarmExpense {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  category          String   // seeds, fertilizers, labor, equipment, etc
  description       String
  amount            Float
  date              DateTime @default(now())
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@index([date])
  @@map("farm_expenses")
}

model FarmRevenue {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  period            String   // YYYY-MM
  totalProduceSales Float    @default(0)
  otherIncome       Float    @default(0)
  totalRevenue      Float    @default(0)
  
  reportData        String?  // JSON for detailed breakdown
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([tenantId, period])
  @@index([tenantId])
  @@map("farm_revenue")
}

model FarmMetrics {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  period            String   // YYYY-MM
  totalPlots        Int      @default(0)
  totalLivestock    Int      @default(0)
  totalProduceHarvested Float @default(0)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([tenantId, period])
  @@index([tenantId])
  @@map("farm_metrics")
}

// ============================================================================
// NOTIFICATIONS & AUDIT
// ============================================================================

model Notification {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // For student notifications (optional)
  studentId         String?
  student           Student? @relation("student_notifications", fields: [studentId], references: [id], onDelete: SetNull)
  
  title             String
  message           String
  type              String   // info, warning, error, success
  
  read              Boolean  @default(false)
  readAt            DateTime?
  
  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([studentId])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  userId            String
  user              User     @relation("user_actions", fields: [userId], references: [id], onDelete: Cascade)
  
  action            String   // create, read, update, delete
  entity            String   // Student, Staff, etc
  entityId          String
  changes           String?  // JSON of changes made
  
  timestamp         DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([timestamp])
  @@map("audit_logs")
}

model SystemLog {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  level             String   // info, warn, error, debug
  message           String
  context           String?  // JSON additional context
  
  timestamp         DateTime @default(now())

  @@index([tenantId])
  @@index([level])
  @@index([timestamp])
  @@map("system_logs")
}
